<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Body>
    <ReportItems>
      <Textbox Name="HeaderTitle">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>HÓA ĐƠN BÁN HÀNG</Value>
                <Style>
                  <FontSize>18pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Center</TextAlign>
            </Style>
          </Paragraph>
        </Paragraphs>
        <Top>1in</Top>
        <Left>0in</Left>
        <Height>0.4in</Height>
        <Width>6.5in</Width>
        <Style>
          <Border>
            <Style>None</Style>
          </Border>
        </Style>
      </Textbox>
      <Textbox Name="SellerInfo">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=Parameters!NguoiBan_Ten.Value</Value>
                <Style>
                  <FontSize>12pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="Địa chỉ: " &amp; Parameters!NguoiBan_DiaChi.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="MST: " &amp; Parameters!NguoiBan_MaSoThue.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Top>0in</Top>
        <Left>0in</Left>
        <Height>0.8in</Height>
        <Width>4in</Width>
        <Style>
          <Border>
            <Style>None</Style>
          </Border>
        </Style>
      </Textbox>
      <Textbox Name="BuyerInfo">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="Khách hàng: " &amp; Parameters!NguoiMua_Ten.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="Địa chỉ: " &amp; Parameters!NguoiMua_DiaChi.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Top>1.5in</Top>
        <Left>0in</Left>
        <Height>0.4in</Height>
        <Width>6.5in</Width>
        <Style>
          <Border>
            <Style>None</Style>
          </Border>
        </Style>
      </Textbox>
      <Tablix Name="TablixChiTiet">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>0.5in</Width></TablixColumn>
            <TablixColumn><Width>2.5in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
            <TablixColumn><Width>1.2in</Width></TablixColumn>
            <TablixColumn><Width>1.5in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.3in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="H_STT"><Paragraphs><Paragraph><TextRuns><TextRun><Value>STT</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H_TenSP"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Tên Sản Phẩm</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H_SL"><Paragraphs><Paragraph><TextRuns><TextRun><Value>SL</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H_DonGia"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Đơn Giá</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H_ThanhTien"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Thành Tiền</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <TablixRow>
              <Height>0.3in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="STT"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=RowNumber(Nothing)</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="TenSanPham"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!TenSanPham.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="SoLuongBan"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!SoLuongBan.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Center</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="DonGiaBan"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!DonGiaBan.Value</Value><Style><Format>N0</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Right</TextAlign></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="ThanhTien"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ThanhTien.Value</Value><Style><Format>N0</Format></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><Border><Style>Solid</Style></Border><TextAlign>Right</TextAlign></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy><TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers></TablixColumnHierarchy>
        <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember><TablixMember><Group Name="Details"/></TablixMember></TablixMembers></TablixRowHierarchy>
        <DataSetName>DanhSachHoaDon_ChiTiet</DataSetName>
        <Top>2in</Top>
        <Left>0in</Left>
        <Height>0.6in</Height>
        <Width>6.5in</Width>
      </Tablix>
      <Textbox Name="Total">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="Tổng cộng: " &amp; Format(CDbl(Parameters!TongTien.Value), "N0") &amp; " VNĐ"</Value>
                <Style>
                  <FontSize>12pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Right</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>2.7in</Top>
        <Left>0in</Left>
        <Height>0.3in</Height>
        <Width>6.5in</Width>
      </Textbox>
      <Textbox Name="DateCreated">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=Parameters!NgayLap.Value</Value>
                <Style />
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Right</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>1.4in</Top>
        <Left>4.5in</Left>
        <Height>0.2in</Height>
        <Width>2in</Width>
      </Textbox>
    </ReportItems>
    <Height>4in</Height>
  </Body>
  <Width>6.5in</Width>
  <Page>
    <LeftMargin>1in</LeftMargin>
    <RightMargin>1in</RightMargin>
    <TopMargin>1in</TopMargin>
    <BottomMargin>1in</BottomMargin>
  </Page>
  <DataSources>
    <DataSource Name="QLBHDataSet">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DanhSachHoaDon_ChiTiet">
      <Query>
        <DataSourceName>QLBHDataSet</DataSourceName>
        <CommandText>/* Local Query */</CommandText>
      </Query>
      <Fields>
        <Field Name="ID"><DataField>ID</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="HoaDonID"><DataField>HoaDonID</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="SanPhamID"><DataField>SanPhamID</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="TenSanPham"><DataField>TenSanPham</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SoLuongBan"><DataField>SoLuongBan</DataField><rd:TypeName>System.Int16</rd:TypeName></Field>
        <Field Name="DonGiaBan"><DataField>DonGiaBan</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ThanhTien"><DataField>ThanhTien</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="NgayLap"><DataType>String</DataType><Prompt>NgayLap</Prompt></ReportParameter>
    <ReportParameter Name="NguoiBan_Ten"><DataType>String</DataType><Prompt>NguoiBan_Ten</Prompt></ReportParameter>
    <ReportParameter Name="NguoiBan_DiaChi"><DataType>String</DataType><Prompt>NguoiBan_DiaChi</Prompt></ReportParameter>
    <ReportParameter Name="NguoiBan_MaSoThue"><DataType>String</DataType><Prompt>NguoiBan_MaSoThue</Prompt></ReportParameter>
    <ReportParameter Name="NguoiMua_Ten"><DataType>String</DataType><Prompt>NguoiMua_Ten</Prompt></ReportParameter>
    <ReportParameter Name="NguoiMua_DiaChi"><DataType>String</DataType><Prompt>NguoiMua_DiaChi</Prompt></ReportParameter>
    <ReportParameter Name="NguoiMua_MaSoThue"><DataType>String</DataType><Prompt>NguoiMua_MaSoThue</Prompt></ReportParameter>
    <ReportParameter Name="TongTien"><DataType>String</DataType><Prompt>TongTien</Prompt></ReportParameter>
  </ReportParameters>
</Report>
